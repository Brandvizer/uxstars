# Supabase — kopieer naar .env.local en vul de waarden in
# (Project Settings → API in het Supabase-dashboard)

# Publiek (mag in de browser): project-URL en anon key
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key

# Geheim: alleen server-side / seed-script. NOOIT in de browser of in git.
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# Lokaal alleen op de exFAT externe schijf: buildcache naar APFS.
# Laat leeg/weg op andere machines en op Vercel.
# UXSTARS_DIST_DIR=/Users/JOU/.cache/uxstars-next/build
